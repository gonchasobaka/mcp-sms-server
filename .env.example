# === SMS Providers (at least one required) ===
FIVESIM_API_KEY=
SMSACTIVATE_API_KEY=
ONLINESIM_API_KEY=

# === Server ===
PORT=3000
TRANSPORT=sse
MARGIN_MULTIPLIER=2
SERVER_URL=https://your-app.up.railway.app

# === LemonSqueezy (payments) ===
LEMON_SIGNING_SECRET=your_webhook_signing_secret
# Map variant IDs to balances: "variant_id:balance_usd,..."
LEMON_PLANS=123456:10,234567:25,345678:50

# === Resend (email) ===
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=MCP SMS <noreply@yourdomain.com>
